{
  "mcpServers": {
    "batondeck": {
      "command": "npx",
      "args": [
        "-y",
        "mcp-remote",
        "https://mcp.batondeck.com/mcp",
        "--header",
        "X-BatonDeck-Agent:${BATONDECK_AGENT}"
      ],
      "env": {
        "BATONDECK_AGENT": "my-agent"
      }
    }
  }
}